	{article.pageheader {padding: 1.5em 0;}.ast-separate-container .ast-article-post, .ast-separate-container .ast-article-single{padding: 1em !important;}}
.author article {width: 100%;}
.single-post h1{text-transform:initial !important;}
table, td, th {border: 1px solid #e0e0e0;}
table {border-collapse: collapse;}
th {color: var(--ast-global-color-0) !important; font-weight:600; }
#ast-fixed-header .main-header-bar {box-shadow: 0 0 5px rgba(0,0,0,0.1);}
.ast-separate-container .ast-article-post, .ast-separate-container .ast-article-single{padding: 3em 6.67em 4em;}
.ast-archive-description p{font-size:16px;}

@media print {.ast-header-breadcrumb,.kk-star-ratings,.ast-post-social-sharing,.widget-area.secondary,.site-footer-below-section-2,.site-header-primary-section-right {display: none !important;}}

