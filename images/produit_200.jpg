.uael-post__thumbnail {text-align:center;}
.uael-post-image-background .uael-post__thumbnail img {min-width:inherit}

.single .entry-header .post-thumb {
	text-align:center;
}

.single .entry-header .post-thumb img {
	max-height:600px;
	width:auto
}		</style>
