<div class="entry-content clear"
	itemprop="text">

	
			<div data-elementor-type="wp-page" data-elementor-id="2500" class="elementor elementor-2500" data-elementor-post-type="page">
						<section class="elementor-section elementor-top-section elementor-element elementor-element-dcbaa55 elementor-section-boxed elementor-section-height-default elementor-section-height-default" data-id="dcbaa55" data-element_type="section">
